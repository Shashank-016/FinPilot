# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/financial_planner

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Google OAuth (optional — only needed for Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:5173

# Hugging Face (optional — used for LLM categorization fallback)
HF_API_KEY=

# AI chat (optional — get from console.anthropic.com and app.tavily.com)
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# IMAP email polling (optional — auto-logs HDFC transaction emails)
# Gmail: enable 2FA then create an App Password at myaccount.google.com/apppasswords
IMAP_HOST=imap.gmail.com
IMAP_EMAIL=
IMAP_PASSWORD=
IMAP_USER_ID=
